{
  "name": "project",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\" \"npm run dev:shared\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev:shared": "npm run dev --workspace=shared",
    "build": "npm run build --workspaces",
    "build:client": "npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "start": "npm run start --workspace=server",
    "prepare-dev": "npm install && cd ./server && npm install && cd .. && cd ./shared && npm run build && cd .. && cd ./client && npm install",
    "clear": "npm run clear:node_modules && npm run clear:dist",
    "clear:node_modules": "rm -rf ./node_modules && cd ./client && rm -rf ./node_modules && cd ../server && rm -rf ./node_modules",
    "clear:dist": "rm -rf ./dist && cd ./client && rm -rf ./dist && cd ../server && rm -rf ./dist && cd ../shared && rm -rf ./dist"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@types/react-redux": "^7.1.34",
    "@types/redux-thunk": "^2.1.32",
    "react-redux": "^9.2.0",
    "redux-thunk": "^3.1.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "webpack-cli": "^7.0.2"
  }
}
