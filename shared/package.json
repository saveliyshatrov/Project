{
  "name": "shared",
  "version": "1.0.0",
  "main": "dist/server/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./constants": "./dist/client/constants/index.js",
    "./resolver": "./dist/client/resolver/index.js",
    "./resolver/*": "./dist/client/resolver/*.js"
  },
  "scripts": {
    "build": "npm run clean && webpack",
    "build:client": "npm run clean && webpack --env target=client",
    "build:server": "npm run clean && webpack --env target=server",
    "dev": "webpack --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "nodemon": "^3.1.14"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/webpack": "^5.28.5",
    "copy-webpack-plugin": "^14.0.0",
    "glob": "^13.0.6",
    "package-json-from-dist": "^1.0.1",
    "rimraf": "^6.1.3",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  }
}
