{
    "name": "shared",
    "version": "1.0.0",
    "main": "dist/server/index.cjs",
    "types": "dist/server/index.d.ts",
    "type": "module",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": {
                "import": "./dist/client/index.d.ts",
                "require": "./dist/server/index.d.ts"
            },
            "import": "./dist/client/index.js",
            "require": "./dist/server/index.cjs",
            "default": "./dist/client/index.js"
        },
        "./auth": {
            "types": {
                "import": "./dist/client/auth/index.d.ts",
                "require": "./dist/server/auth/index.d.ts"
            },
            "import": "./dist/client/auth/index.js",
            "require": "./dist/server/auth/index.cjs",
            "default": "./dist/client/auth/index.js"
        },
        "./constants": {
            "types": {
                "import": "./dist/client/constants/index.d.ts",
                "require": "./dist/server/constants/index.d.ts"
            },
            "import": "./dist/client/constants/index.js",
            "require": "./dist/server/constants/index.cjs",
            "default": "./dist/client/constants/index.js"
        },
        "./resolver": {
            "types": {
                "import": "./dist/client/resolver/index.d.ts",
                "require": "./dist/server/resolver/index.d.ts"
            },
            "import": "./dist/client/resolver/index.js",
            "require": "./dist/server/resolver/index.cjs",
            "default": "./dist/client/resolver/index.js"
        },
        "./resolver/*": {
            "types": {
                "import": "./dist/client/resolver/*.d.ts",
                "require": "./dist/server/resolver/*.d.ts"
            },
            "import": "./dist/client/resolver/*.js",
            "require": "./dist/server/resolver/*.cjs",
            "default": "./dist/client/resolver/*.js"
        },
        "./utils": {
            "types": {
                "import": "./dist/client/utils/index.d.ts",
                "require": "./dist/server/utils/index.d.ts"
            },
            "import": "./dist/client/utils/index.js",
            "require": "./dist/server/utils/index.cjs",
            "default": "./dist/client/utils/index.js"
        },
        "./utils/*": {
            "types": {
                "import": "./dist/client/utils/*.d.ts",
                "require": "./dist/server/utils/*.d.ts"
            },
            "import": "./dist/client/utils/*.js",
            "require": "./dist/server/utils/*.cjs",
            "default": "./dist/client/utils/*.js"
        }
    },
    "scripts": {
        "build": "pnpm clean && pnpm gen:exports && (cd .. && webpack --config webpack.shared.config.ts) && pnpm build:types",
        "gen:exports": "pnpm exec tsx scripts/generate-exports.ts",
        "build:types": "pnpm exec tsx scripts/distribute-types.ts",
        "watch:types": "tsc --project tsconfig.types.json --watch",
        "dev": "pnpm gen:exports && pnpm build:types && (tsc --project tsconfig.types.json --watch --preserveWatchOutput & pnpm exec tsx scripts/watch-types.ts & (cd .. && webpack --watch --config webpack.shared.config.ts))",
        "clean": "rimraf dist",
        "test": "jest --config jest.config.ts"
    },
    "devDependencies": {
        "@types/node": "25.6.0",
        "glob": "13.0.6",
        "rimraf": "6.1.3",
        "ts-loader": "9.5.7",
        "typescript": "5.3.3",
        "webpack": "5.106.2",
        "webpack-cli": "7.0.2"
    }
}
