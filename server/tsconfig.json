{
  "compilerOptions": {
    "module": "nodenext",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "moduleResolution": "NodeNext",
    "paths": {
      "shared": [
        "./../shared/dist/server"
      ],
      "shared/*": [
        "./../shared/dist/server/*"
      ],
      "@*": ["*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
