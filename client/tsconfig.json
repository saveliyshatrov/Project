{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "src",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "shared/*": ["node_modules/shared/*"],
      "@*": ["*"]
    }
  },
  "preserveSymlinks": true,
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
